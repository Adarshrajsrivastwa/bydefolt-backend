# Copy to `.env` and fill in real values. Never commit `.env`.

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB (required) ---
MONGODB_URI=mongodb://127.0.0.1:27017/bydefolt

# --- JWT (required) ---
JWT_SECRET=change_me_to_a_strong_secret_in_production
JWT_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=*

# --- Rate limiting (optional) ---
# RATE_LIMIT_MAX=300
# RATE_LIMIT_WINDOW_MS=900000

# --- Email (optional; OTP logged to console if SMTP not set) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="ByDefolt <no-reply@yourdomain.com>"
