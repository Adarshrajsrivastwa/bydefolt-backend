# Copy to .env and adjust. Never commit .env to git.

PORT=5000
NODE_ENV=development

# MongoDB (local: mongodb://127.0.0.1:27017/bydefolt)
MONGODB_URI=mongodb://127.0.0.1:27017/bydefolt

# Use a long random string in production (e.g. openssl rand -base64 48)
JWT_SECRET=change_me_to_a_strong_secret_in_production
JWT_EXPIRES_IN=7d

# Comma-separated origins, or * for any (not recommended in production)
CORS_ORIGIN=*

# All outbound email (OTP, welcome, admin approve/reject, etc.) uses Nodemailer + SMTP below.
# If omitted, sends are skipped and previews may be logged to the server console.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="ByDefolt <no-reply@yourdomain.com>"
